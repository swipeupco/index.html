<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OTRV Email Signature Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #ffffff;
    --grey: #f2f2f0;
    --mid: #888;
    --accent: #c8a96e;
    --border: #e0e0dc;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--grey);
    color: var(--black);
    min-height: 100vh;
  }

  /* Header */
  header {
    background: var(--black);
    padding: 20px 40px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  header img {
    height: 44px;
    width: 44px;
    border-radius: 6px;
  }
  header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: var(--white);
    letter-spacing: 2px;
  }
  header span {
    font-size: 12px;
    color: var(--mid);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-left: 2px;
  }

  /* Layout */
  .layout {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 0;
    min-height: calc(100vh - 84px);
  }

  /* Form panel */
  .form-panel {
    background: var(--white);
    padding: 36px 32px;
    border-right: 1px solid var(--border);
    overflow-y: auto;
  }

  .form-panel h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    margin-bottom: 4px;
    color: var(--black);
  }
  .form-panel p.sub {
    font-size: 13px;
    color: var(--mid);
    margin-bottom: 28px;
  }

  .field {
    margin-bottom: 18px;
  }
  label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 6px;
  }
  input {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--black);
    background: var(--white);
    transition: border-color 0.2s;
    outline: none;
  }
  input:focus {
    border-color: var(--black);
  }
  input::placeholder {
    color: #bbb;
  }

  /* Preview panel */
  .preview-panel {
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .preview-panel h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--black);
    margin-bottom: -12px;
  }

  .preview-box {
    background: var(--white);
    border-radius: 12px;
    padding: 28px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
    border: 1px solid var(--border);
  }

  /* Copy section */
  .copy-section {
    background: var(--black);
    border-radius: 12px;
    padding: 24px 28px;
  }
  .copy-section h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: var(--white);
    letter-spacing: 2px;
    margin-bottom: 6px;
  }
  .copy-section p {
    font-size: 12px;
    color: var(--mid);
    margin-bottom: 16px;
    line-height: 1.6;
  }
  .copy-btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-copy {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
    letter-spacing: 0.3px;
  }
  .btn-primary {
    background: var(--white);
    color: var(--black);
  }
  .btn-primary:hover { background: #e8e8e8; }
  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 1.5px solid #333;
  }
  .btn-secondary:hover { border-color: #666; }

  .btn-copy.copied {
    background: #22c55e !important;
    color: white !important;
    border-color: #22c55e !important;
  }

  /* Instructions */
  .instructions {
    background: var(--white);
    border-radius: 12px;
    padding: 24px 28px;
    border: 1px solid var(--border);
  }
  .instructions h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1.5px;
    margin-bottom: 12px;
  }
  .steps {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .step {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 13px;
    color: #444;
    line-height: 1.5;
  }
  .step-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--black);
    color: white;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
</style>
</head>
<body>

<header>
  <img src="data:image/jpeg;base64," alt="OTRV">
  <div>
    <h1>Signature Generator</h1>
    <span>Off Track RV</span>
  </div>
</header>

<div class="layout">

  <!-- FORM -->
  <div class="form-panel">
    <h2>Your Details</h2>
    <p class="sub">Fill in your info and the signature updates instantly.</p>

    <div class="field">
      <label>Full Name</label>
      <input type="text" id="f-name" placeholder="e.g. Justin Borg" oninput="updateSig()">
    </div>
    <div class="field">
      <label>Job Title</label>
      <input type="text" id="f-title" placeholder="e.g. Managing Director" oninput="updateSig()">
    </div>
    <div class="field">
      <label>Email Address</label>
      <input type="email" id="f-email" placeholder="e.g. justin@offtrackrv.com" oninput="updateSig()">
    </div>
    <div class="field">
      <label>Phone</label>
      <input type="text" id="f-phone" placeholder="e.g. 03 9970 1111" oninput="updateSig()">
    </div>
    <div class="field">
      <label>Address</label>
      <input type="text" id="f-address" placeholder="e.g. 1946 Sydney Road, Campbellfield, VIC, 3061" oninput="updateSig()">
    </div>
    <div class="field">
      <label>Website</label>
      <input type="text" id="f-website" placeholder="e.g. offtrackrv.com" oninput="updateSig()">
    </div>
  </div>

  <!-- PREVIEW + COPY -->
  <div class="preview-panel">
    <h2>Live Preview</h2>

    <div class="preview-box">
      <div id="sig-preview"></div>
    </div>

    <div class="copy-section">
      <h3>Install Your Signature</h3>
      <p>Click "Copy Signature" then paste directly into Gmail, Outlook, or Apple Mail signature settings.</p>
      <div class="copy-btns">
        <button class="btn-copy btn-primary" onclick="copySignature()">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          Copy Signature
        </button>
        <button class="btn-copy btn-secondary" onclick="copyRawHTML()">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Copy Raw HTML
        </button>
      </div>
    </div>

    <div class="instructions">
      <h3>How to Install</h3>
      <div class="steps">
        <div class="step"><div class="step-num">1</div><span>Fill in your details on the left — the preview updates live.</span></div>
        <div class="step"><div class="step-num">2</div><span><strong>Gmail:</strong> Settings → See all settings → Signature → Create new → Paste.</span></div>
        <div class="step"><div class="step-num">3</div><span><strong>Outlook:</strong> File → Options → Mail → Signatures → New → Paste.</span></div>
        <div class="step"><div class="step-num">4</div><span><strong>Apple Mail:</strong> Mail → Settings → Signatures → + → uncheck "Always match font" → Paste.</span></div>
      </div>
    </div>

  </div>
</div>

<script>
const ASSETS = {
  logo: "data:image/jpeg;base64,",
  ig: "data:image/png;base64,",
  tiktok: "data:image/png;base64,",
  yt: "data:image/png;base64,",
  gif: "data:image/gif;base64,                     

function getValues() {
  return {
    name:    document.getElementById('f-name').value    || 'Your Name',
    title:   document.getElementById('f-title').value   || 'Job Title',
    email:   document.getElementById('f-email').value   || 'email@offtrackrv.com',
    phone:   document.getElementById('f-phone').value   || '03 9970 1111',
    address: document.getElementById('f-address').value || '1946 Sydney Road, Campbellfield, VIC, 3061',
    website: document.getElementById('f-website').value || 'offtrackrv.com',
  };
}

function buildSignatureHTML(v) {
  return `<table cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:600px;">
<tbody><tr><td style="height:24px;line-height:24px;font-size:24px;">&nbsp;</td></tr>
<tr><td style="height:24px;line-height:24px;font-size:24px;">&nbsp;</td></tr>
</tbody></table>
<table cellpadding="0" cellspacing="0" border="0" style="background:#fffffe;background-color:#fffffe;width:100%;max-width:600px;">
<tbody>
<tr>
<td style="border:none;direction:ltr;font-size:0;padding:0;text-align:left;">
<div style="font-size:0;line-height:0;text-align:left;display:inline-block;width:100%;direction:ltr;">

<div style="font-size:0;text-align:left;direction:ltr;display:inline-block;vertical-align:middle;width:33.3333%;">
<table border="0" cellpadding="0" cellspacing="0" role="none" style="background:transparent;border:none;vertical-align:middle;width:100%">
<tbody><tr><td align="left" style="font-size:0;padding:0;word-break:break-word;">
<table border="0" cellpadding="0" cellspacing="0" role="none" style="border-collapse:collapse;border-spacing:0;">
<tbody><tr><td style="width:199px;">
<img src="${ASSETS.logo}" style="border:0;display:block;outline:none;text-decoration:none;height:auto;width:100%;font-size:13px;" width="199" height="auto">
</td></tr></tbody></table>
</td></tr></tbody></table>
</div>

<div style="font-size:0;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:2.6667%;">
<table border="0" cellpadding="0" cellspacing="0" role="none" width="100%"><tbody><tr>
<td style="vertical-align:top;padding:0;"><table border="0" cellpadding="0" cellspacing="0" role="none" width="100%"><tbody></tbody></table></td>
</tr></tbody></table>
</div>

<div style="font-size:0;text-align:left;direction:ltr;display:inline-block;vertical-align:middle;width:64%;">
<table border="0" cellpadding="0" cellspacing="0" role="none" style="background:transparent;border:none;vertical-align:middle;width:100%">
<tbody>
<tr><td align="left" style="font-size:0;padding-bottom:4px;word-break:break-word;">
<div style="font-family:'Inter','Arial',sans-serif;font-size:20px;font-weight:700;line-height:145%;text-align:left;color:#000000;">
<p style="margin:0;">${v.name}</p></div>
</td></tr>
<tr><td align="left" style="font-size:0;padding-bottom:4px;word-break:break-word;">
<div style="font-family:'Inter','Arial',sans-serif;font-size:13px;font-weight:400;line-height:115%;text-align:left;color:#777777;">
<p style="margin:0;">${v.title}</p></div>
</td></tr>
<tr><td style="font-size:0;padding:0;padding-bottom:4px;" aria-hidden="true"><div style="height:4px;line-height:4px;">&nbsp;</div></td></tr>
<tr><td align="left" style="font-size:0;padding-bottom:4px;word-break:break-word;">
<div style="font-family:'Inter','Arial',sans-serif;font-size:13px;font-weight:400;line-height:138%;text-align:left;color:#111111;">
<p style="margin:0;">E: ${v.email}</p></div>
</td></tr>
<tr><td align="left" style="font-size:0;padding-bottom:4px;word-break:break-word;">
<div style="font-family:'Inter','Arial',sans-serif;font-size:13px;font-weight:400;line-height:138%;text-align:left;color:#111111;">
<p style="margin:0;">T: ${v.phone}</p></div>
</td></tr>
<tr><td align="left" style="font-size:0;padding-bottom:4px;word-break:break-word;">
<div style="font-family:'Inter','Arial',sans-serif;font-size:13px;font-weight:400;line-height:138%;text-align:left;color:#111111;">
<p style="margin:0;">A: ${v.address}</p></div>
</td></tr>
<tr><td align="left" style="font-size:0;padding-bottom:4px;word-break:break-word;">
<div style="font-family:'Inter','Arial',sans-serif;font-size:13px;font-weight:400;line-height:138%;text-align:left;color:#111111;">
<p style="margin:0;">W: <a href="https://${v.website}" style="color:#111111;text-decoration:none;" target="_blank"><span style="text-decoration:underline;">${v.website}</span></a></p></div>
</td></tr>
<tr><td style="font-size:0;padding:0;padding-bottom:4px;" aria-hidden="true"><div style="height:4px;line-height:4px;">&nbsp;</div></td></tr>
<tr><td align="left" style="font-size:0;padding:0;padding-bottom:0;word-break:break-word;">
<table align="left" border="0" cellpadding="0" cellspacing="0" role="none" style="float:none;display:inline-table;">
<tbody><tr><td style="padding:0 16px 0 0;vertical-align:middle;">
<table border="0" cellpadding="0" cellspacing="0" role="none" style="width:32px;"><tbody><tr>
<td style="font-size:0;height:32px;vertical-align:middle;width:32px;">
<a href="https://www.instagram.com/off_trackrv/" target="_blank">
<img alt="Instagram" height="32" src="${ASSETS.ig}" style="display:block;" width="32">
</a></td></tr></tbody></table>
</td></tr></tbody></table>
<table align="left" border="0" cellpadding="0" cellspacing="0" role="none" style="float:none;display:inline-table;">
<tbody><tr><td style="padding:0 16px 0 0;vertical-align:middle;">
<table border="0" cellpadding="0" cellspacing="0" role="none" style="width:32px;"><tbody><tr>
<td style="font-size:0;height:32px;vertical-align:middle;width:32px;">
<a href="https://www.tiktok.com/@offtrackrv" target="_blank">
<img alt="TikTok" height="32" src="${ASSETS.tiktok}" style="display:block;" width="32">
</a></td></tr></tbody></table>
</td></tr></tbody></table>
<table align="left" border="0" cellpadding="0" cellspacing="0" role="none" style="float:none;display:inline-table;">
<tbody><tr><td style="padding:0;vertical-align:middle;">
<table border="0" cellpadding="0" cellspacing="0" role="none" style="width:32px;"><tbody><tr>
<td style="font-size:0;height:32px;vertical-align:middle;width:32px;">
<a href="https://www.youtube.com/@OfftrackRV" target="_blank">
<img alt="YouTube" height="32" src="${ASSETS.yt}" style="display:block;" width="32">
</a></td></tr></tbody></table>
</td></tr></tbody></table>
</td></tr>
</tbody></table>
</div>

</div>
</td>
</tr>
</tbody>
</table>

<table cellpadding="0" cellspacing="0" border="0" style="background:transparent;width:100%;max-width:600px;">
<tbody><tr><td style="direction:ltr;font-size:0;padding:0;text-align:center;">
<div style="font-size:0;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;">
<table border="0" cellpadding="0" cellspacing="0" role="none" width="100%"><tbody><tr>
<td style="vertical-align:top;padding:0;"><table border="0" cellpadding="0" cellspacing="0" role="none" width="100%"><tbody><tr>
<td align="left" style="font-size:0;padding:0;word-break:break-word;">
<table border="0" cellpadding="0" cellspacing="0" role="none" style="border-collapse:collapse;border-spacing:0;"><tbody><tr>
<td style="width:600px;">
<img src="${ASSETS.gif}" style="border:0;display:block;outline:none;text-decoration:none;height:auto;width:100%;font-size:13px;" width="600" height="auto">
</td></tr></tbody></table>
</td></tr></tbody></table>
</td></tr></tbody></table>
</div>
</td></tr></tbody></table>

<table cellpadding="0" cellspacing="0" border="0" style="background:transparent;width:100%;max-width:600px;">
<tbody><tr>
<td style="padding:10px 0 0 0;font-size:10px;color:#888888;line-height:1.6;font-family:'Inter','Arial',sans-serif;">
The content of this email is confidential and intended for the recipient specified in message only. It is strictly forbidden to share any part of this message with any third party, without a written consent of the sender. If you received this message by mistake, please reply to this message and follow with its deletion, so that we can ensure such a mistake does not occur in the future.
</td>
</tr></tbody></table>`;
}

function updateSig() {
  const v = getValues();
  document.getElementById('sig-preview').innerHTML = buildSignatureHTML(v);
}

async function copySignature() {
  const v = getValues();
  const sigHTML = buildSignatureHTML(v);
  const btn = event.currentTarget;
  try {
    const blob = new Blob([sigHTML], { type: 'text/html' });
    const item = new ClipboardItem({ 'text/html': blob });
    await navigator.clipboard.write([item]);
    btn.classList.add('copied');
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Copied!`;
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy Signature`;
    }, 2500);
  } catch(e) {
    alert('Copy failed. Please use "Copy Raw HTML" instead.');
  }
}

async function copyRawHTML() {
  const v = getValues();
  const sigHTML = buildSignatureHTML(v);
  const btn = event.currentTarget;
  try {
    await navigator.clipboard.writeText(sigHTML);
    btn.classList.add('copied');
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Copied!`;
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg> Copy Raw HTML`;
    }, 2500);
  } catch(e) {
    alert('Copy failed.');
  }
}

// Init with placeholder values
updateSig();
</script>
</body>
</html>
